### ============================================================
### University Management System — API Test Requests
### Use with VS Code REST Client extension
### Run requests in order: Login first, then copy token to @token
### ============================================================

@baseUrl = http://localhost:5000/api/v1
@token = PASTE_YOUR_TOKEN_HERE

### -----------------------------------------------------------
### 1. Health Check
### -----------------------------------------------------------
GET {{baseUrl}}/health

### -----------------------------------------------------------
### 2. Login as Admin (seed account)
### -----------------------------------------------------------
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "admin@ums.edu.pk",
    "password": "Admin@123"
}

### -----------------------------------------------------------
### 3. Login as Student (seed account — linked to student_id 1)
### -----------------------------------------------------------
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "ali.ahmad@stu.ums.edu.pk",
    "password": "Admin@123"
}

### -----------------------------------------------------------
### 4. Login as Instructor (seed account — linked to instructor_id 1)
### -----------------------------------------------------------
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "ahmed.khan@ums.edu.pk",
    "password": "Admin@123"
}

### -----------------------------------------------------------
### 5. Register a new Student (no token needed)
### -----------------------------------------------------------
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "email": "newstudent@test.com",
    "password": "TestPassword123"
}

### -----------------------------------------------------------
### 6. Register an Instructor (requires Admin token)
### -----------------------------------------------------------
POST {{baseUrl}}/auth/register
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "email": "newinstructor@test.com",
    "password": "TestPassword123",
    "role": "Instructor"
}

### -----------------------------------------------------------
### 7. Get All Courses
### -----------------------------------------------------------
GET {{baseUrl}}/courses
Authorization: Bearer {{token}}

### -----------------------------------------------------------
### 8. Get All Sections
### -----------------------------------------------------------
GET {{baseUrl}}/courses/sections
Authorization: Bearer {{token}}

### -----------------------------------------------------------
### 9. Enroll Student (ACID Transaction — use Student token)
### -----------------------------------------------------------
POST {{baseUrl}}/enrollment
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "student_id": 1,
    "section_id": 17
}

### -----------------------------------------------------------
### 10. Get My Fees (Student token)
### -----------------------------------------------------------
GET {{baseUrl}}/fees/my-fees
Authorization: Bearer {{token}}

### -----------------------------------------------------------
### 11. Pay Fee (ACID Transaction — use Student token)
### -----------------------------------------------------------
POST {{baseUrl}}/fees/pay
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "fee_id": 3,
    "payment_amount": 50000
}

### -----------------------------------------------------------
### 12. Mark Attendance (Instructor token)
### -----------------------------------------------------------
POST {{baseUrl}}/attendance
Content-Type: application/json
Authorization: Bearer {{token}}

{
    "section_id": 3,
    "date": "2026-04-19",
    "records": [
        { "student_id": 1, "status": "Present" },
        { "student_id": 2, "status": "Absent" }
    ]
}

### -----------------------------------------------------------
### 13. Get My Attendance (Student token)
### -----------------------------------------------------------
GET {{baseUrl}}/attendance/my-records
Authorization: Bearer {{token}}

### -----------------------------------------------------------
### 14. Admin Dashboard (Admin token)
### -----------------------------------------------------------
GET {{baseUrl}}/admin/dashboard
Authorization: Bearer {{token}}
